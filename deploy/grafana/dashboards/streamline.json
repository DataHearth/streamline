{
  "title": "Streamline",
  "uid": "streamline",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Movies",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "expr": "streamline_movies_total" }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "TV Shows",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "expr": "streamline_tvshows_total" }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Episodes",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "expr": "streamline_episodes_total" }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Users",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "expr": "streamline_users_total" }]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Requests",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "expr": "streamline_requests_total" }]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Downloads",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "expr": "streamline_downloads_total" }]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Request rate (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum by (http_route) (rate(http_server_request_duration_seconds_count[1m]))",
          "legendFormat": "{{http_route}}"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Latency p50/p95",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_server_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "5xx error rate",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{http_response_status_code=~\"5..\"}[5m]))",
          "legendFormat": "5xx/s"
        }
      ]
    },
    {
      "id": 20,
      "type": "logs",
      "title": "Recent errors",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 20 },
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" },
      "targets": [{ "expr": "{severity_text=~\"ERROR|WARN|CRITICAL\"}" }]
    }
  ]
}
