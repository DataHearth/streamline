# Copy to .env and fill in the blanks before `docker compose up`.
# See compose.yaml for how each value is wired into the stack.

# --- Container user / timezone ---
# Applied to streamline, qbittorrent, prowlarr, and plex.
PUID=1000
PGID=100
TZ=Etc/UTC

# --- Network ---
# CIDR of your LAN — allows direct LAN access to the webuis through gluetun's
# VPN killswitch.
LAN_NETWORK=192.168.0.0/16

# --- VPN (gluetun) ---
# Your gluetun VPN provider id (e.g. protonvpn, mullvad, windscribe, ...).
# See https://github.com/qdm12/gluetun-wiki for supported providers.
VPN_SERVICE_PROVIDER=protonvpn
VPN_TYPE=wireguard
# The PrivateKey from your provider's generated WireGuard config. Built-in
# providers auto-supply the address; only set WIREGUARD_ADDRESSES for `custom`.
WIREGUARD_PRIVATE_KEY=
# Optional: restrict server selection (comma-separated, e.g. Switzerland).
SERVER_COUNTRIES=
# Only pick servers that support port forwarding, then enable it.
PORT_FORWARD_ONLY=on
VPN_PORT_FORWARDING=on

# --- Plex ---
# Fresh claim token from https://www.plex.tv/claim/ (4-min expiry), first boot
# only. Afterwards the server is bound to your account; leave empty.
PLEX_CLAIM=
