{
  "$schema": "https://json-schema.org/draft-07/schema",
  "type": "object",
  "definitions": {
    "libraryVolume": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "existingClaim": { "type": "string" },
        "mountPath": { "type": "string" },
        "size": { "type": "string" },
        "storageClass": { "type": "string" },
        "accessMode": {
          "enum": ["ReadWriteOnce", "ReadWriteOncePod", "ReadWriteMany"]
        }
      }
    }
  },
  "properties": {
    "image": {
      "type": "object",
      "required": ["repository", "pullPolicy"],
      "properties": {
        "repository": { "type": "string" },
        "tag": { "type": "string" },
        "pullPolicy": { "enum": ["Always", "IfNotPresent", "Never"] }
      }
    },
    "replicaCount": { "type": "integer", "minimum": 1, "maximum": 1 },
    "persistence": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "size": { "type": "string" },
        "storageClass": { "type": "string" },
        "accessMode": { "enum": ["ReadWriteOnce", "ReadWriteOncePod"] }
      }
    },
    "service": {
      "type": "object",
      "properties": {
        "type": { "enum": ["ClusterIP", "NodePort", "LoadBalancer"] },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" }
      }
    },
    "gateway": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "observability": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "secrets": {
      "type": "object",
      "description": "STREAMLINE_*-prefixed env vars rendered into a Secret (scalar config overrides).",
      "additionalProperties": { "type": "string" }
    },
    "secretFiles": {
      "type": "object",
      "description": "Mount an existing Secret as files, referenced from config via *_file paths.",
      "properties": {
        "enabled": { "type": "boolean" },
        "existingSecret": { "type": "string" },
        "mountPath": { "type": "string" }
      }
    },
    "extraEnv": { "type": "array" },
    "library": {
      "type": "object",
      "description": "Media/download volumes. Use shared (one filesystem) for hardlink import; media+downloads are separate PVCs for copy/move.",
      "properties": {
        "shared": { "$ref": "#/definitions/libraryVolume" },
        "media": { "$ref": "#/definitions/libraryVolume" },
        "downloads": { "$ref": "#/definitions/libraryVolume" }
      }
    }
  }
}
